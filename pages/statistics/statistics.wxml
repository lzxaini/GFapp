<view class="statistics_container">
  <!-- 顶部导航栏固定 -->
  <t-navbar t-class="navBar" left-arrow="{{false}}" title="统计数据" />
  <view class="nav_bg" style="top: {{capsuleHeight - 15}}px">
    <image class="bg_img" src="../../static/icon/recharge_nav_bg.png" />
  </view>
  <!-- 滚动内容区域 -->
  <scroll-view class="scroll-content" scroll-y="true" scroll-with-animation="true" bindscrolltolower="onReachBottom" refresher-enabled="{{true}}" refresher-triggered="{{refresher}}" bindrefresherrefresh="pullDownToRefresh">
    <view class="page_title">关键指标</view>
    <view class="grid_box">
      <view class="item_box blue">
        <image class="icon" src="../../static/icon/s_1.png" />
        <view class="title">总点数余额</view>
        <view class="content">2847360</view>
        <view class="tips">pts·未消耗余额</view>
      </view>
      <view class="item_box">
        <image class="icon" src="../../static/icon/s_2.png" />
        <view class="title">总点数余额</view>
        <view class="content">2847360</view>
        <view class="tips">pts·未消耗余额</view>
      </view>
      <view class="item_box">
        <image class="icon" src="../../static/icon/s_3.png" />
        <view class="title">总点数余额</view>
        <view class="content">2847360</view>
        <view class="tips">pts·未消耗余额</view>
      </view>
      <view class="item_box">
        <image class="icon" src="../../static/icon/s_4.png" />
        <view class="title">总点数余额</view>
        <view class="content">2847360</view>
        <view class="tips">pts·未消耗余额</view>
      </view>
      <view class="item_box">
        <image class="icon" src="../../static/icon/s_5.png" />
        <view class="title">总点数余额</view>
        <view class="content">2847360</view>
        <view class="tips">pts·未消耗余额</view>
      </view>
      <view class="item_box">
        <image class="icon" src="../../static/icon/s_6.png" />
        <view class="title">总点数余额</view>
        <view class="content">2847360</view>
        <view class="tips">pts·未消耗余额</view>
      </view>
    </view>
    <view class="dep_info">
      <view class="header_box" wx:if="{{!searchFlag}}">
        <view class="page_title">实时点数</view>
        <view class="btn" bindtap="searchClick">
          <t-icon class="icon" name="search"></t-icon>
          查询门店
        </view>
      </view>
      <t-search wx:else class="search" value="{{value}}" center placeholder="搜索机构" bind:change="changeHandle" focus="{{true}}" bind:blur="blurClick"/>
      <view class="table-row table-header">
        <view class="table-cell cell-header cell-big" style="flex: 2;">机构</view>
        <view class="table-cell cell-header" style="flex: 3;min-width: 200rpx;">剩余点数</view>
        <view class="table-cell cell-header" style="flex: 2;">累计充值</view>
      </view>
      <block wx:for="{{12}}" wx:key="index">
        <view class="table-row table-row-big">
          <view class="table-cell textOverflow" style="flex: 2;">{{item.deptName}}</view>
          <view class="table-cell number-cell" style="flex: 3;min-width: 200rpx;">
            <view class="text">+{{item.rechargeAmount}}</view>
            <view class="date">{{item.createTime}}</view>
          </view>
          <view class="table-cell" style="flex: 2;">{{item.previousBalance}}</view>
          <view class="table-cell" style="flex: 2;">{{item.currentBalance}}</view>
        </view>
      </block>
    </view>
  </scroll-view>
</view>
<t-message id="t-message" />